"""
Environment Configuration Template for AegisMedBot
This file contains all required environment variables for the MedIntel Agentic AI Platform.
Copy this file to .env and fill in your actual values.
"""

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application Environment: development, staging, production
ENVIRONMENT=development

# Application Debug Mode: true or false
DEBUG=true

# Secret key for JWT token generation and encryption
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# API Version Prefix
API_V1_PREFIX=/api/v1

# Project name displayed in API documentation
PROJECT_NAME=AegisMedBot

# Application version
VERSION=1.0.0

# ============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ============================================================================

# PostgreSQL Server Hostname or IP
POSTGRES_SERVER=localhost

# PostgreSQL Port (default: 5432)
POSTGRES_PORT=5432

# PostgreSQL Database User
POSTGRES_USER=medintel_user

# PostgreSQL Database Password
POSTGRES_PASSWORD=secure_password_here

# PostgreSQL Database Name
POSTGRES_DB=medintel_db

# Database connection pool size
DATABASE_POOL_SIZE=20

# Database connection max overflow
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis Server Hostname
REDIS_HOST=localhost

# Redis Server Port (default: 6379)
REDIS_PORT=6379

# Redis Password (leave empty if no password)
REDIS_PASSWORD=

# Redis Database number (0-15)
REDIS_DB=0

# Redis connection pool size
REDIS_POOL_SIZE=10

# Redis socket timeout in seconds
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# QDRANT VECTOR DATABASE CONFIGURATION
# ============================================================================

# Qdrant Server Hostname
QDRANT_HOST=localhost

# Qdrant HTTP Port (default: 6333)
QDRANT_PORT=6333

# Qdrant GRPC Port (default: 6334)
QDRANT_GRPC_PORT=6334

# Qdrant API Key (if authentication enabled)
QDRANT_API_KEY=

# Collection name for medical knowledge base
QDRANT_COLLECTION=medical_knowledge

# Vector dimension size (768 for BERT-based models)
EMBEDDING_DIM=768

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Transformer model name from HuggingFace
# Options: microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
#          emilyalsentzer/Bio_ClinicalBERT
#          google/BioBERT-Base-v1.2
TRANSFORMER_MODEL=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext

# Maximum sequence length for tokenization
MAX_SEQUENCE_LENGTH=512

# Batch size for model inference
BATCH_SIZE=32

# Number of workers for data loading
NUM_WORKERS=4

# Device for model inference: cuda or cpu
DEVICE=cuda

# Whether to use half precision (FP16) for inference
USE_FP16=true

# ============================================================================
# LSTM MODEL CONFIGURATION
# ============================================================================

# LSTM hidden layer size
LSTM_HIDDEN_SIZE=256

# Number of LSTM layers
LSTM_NUM_LAYERS=2

# Dropout rate for LSTM
LSTM_DROPOUT=0.3

# Learning rate for LSTM training
LSTM_LEARNING_RATE=0.001

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Maximum number of agent iterations per task
MAX_AGENT_ITERATIONS=5

# Agent timeout in seconds before escalation
AGENT_TIMEOUT_SECONDS=30

# Confidence threshold for human intervention (0.0 to 1.0)
HUMAN_IN_LOOP_THRESHOLD=0.7

# Maximum conversation history to maintain
MAX_CONVERSATION_HISTORY=50

# ============================================================================
# RAG CONFIGURATION
# ============================================================================

# Number of documents to retrieve for RAG
TOP_K_RETRIEVAL=5

# Chunk size for document splitting in characters
CHUNK_SIZE=1000

# Overlap between chunks in characters
CHUNK_OVERLAP=200

# Similarity threshold for document retrieval
SIMILARITY_THRESHOLD=0.75

# Whether to use hybrid search (vector + keyword)
USE_HYBRID_SEARCH=true

# Alpha weight for hybrid search (0=keyword only, 1=vector only)
HYBRID_SEARCH_ALPHA=0.7

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================

# Enable metrics collection
ENABLE_METRICS=true

# Prometheus metrics endpoint
METRICS_ENDPOINT=/metrics

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable OpenTelemetry tracing
ENABLE_TRACING=false

# Jaeger agent host for tracing
JAEGER_AGENT_HOST=localhost

# Jaeger agent port
JAEGER_AGENT_PORT=6831

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT algorithm (HS256, RS256, etc.)
ALGORITHM=HS256

# CORS allowed origins (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:7860,https://medintel.example.com

# Rate limiting: maximum requests per IP per minute
RATE_LIMIT_REQUESTS=100

# Rate limiting time window in seconds
RATE_LIMIT_PERIOD=60

# Whether to enable PHI detection and redaction
ENABLE_PHI_DETECTION=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Log file path (optional, empty for console only)
LOG_FILE_PATH=

# Maximum log file size in MB
LOG_MAX_SIZE=100

# Number of log files to keep
LOG_BACKUP_COUNT=5

# ============================================================================
# API KEYS FOR EXTERNAL SERVICES (Optional)
# ============================================================================

# PubMed API configuration
PUBMED_EMAIL=your-email@example.com
PUBMED_API_KEY=

# ClinicalTrials.gov API
CLINICAL_TRIALS_API_KEY=

# Weather API for transport coordination
WEATHER_API_KEY=

# Maps API for hospital transfers
MAPS_API_KEY=

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Model cache size in GB
MODEL_CACHE_SIZE_GB=4

# Whether to use model quantization
USE_MODEL_QUANTIZATION=false

# Number of threads for CPU inference
CPU_THREADS=4

# Whether to enable response streaming
ENABLE_STREAMING=true

# Maximum response length in tokens
MAX_RESPONSE_TOKENS=1000

# Temperature for response generation
TEMPERATURE=0.7

# Top-p sampling parameter
TOP_P=0.9